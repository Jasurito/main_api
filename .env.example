# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10

# MongoDB
# Set MONGO_URI to override individual fields
MONGO_URI=
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=myuser
MONGO_PASSWORD=mypassword
MONGO_DB=mydb

# Elasticsearch
# Comma-separated list of hosts
ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=mypassword
# OR use an API key instead of user/password
ELASTICSEARCH_API_KEY=
# Set to "false" to disable TLS certificate verification (dev only)
ELASTICSEARCH_VERIFY_CERTS=false

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=main-api
KAFKA_AUTO_OFFSET_RESET=earliest
# PLAINTEXT | SSL | SASL_PLAINTEXT | SASL_SSL
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# Required only when KAFKA_SECURITY_PROTOCOL is SASL_PLAINTEXT or SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
